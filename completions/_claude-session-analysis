#compdef claude-session-analysis

_claude-session-analysis() {
  local -a subcommands=(
    'sessions:List available Claude sessions with filtering and search'
    'timeline:Display session events with filtering and formatting options'
    'file-ops:Extract file operations from a session'
    'resolve:Resolve session ID prefix to full ID or file path'
    'completion:Output shell completion script'
  )

  if (( CURRENT == 2 )); then
    _describe 'subcommand' subcommands
    return
  fi

  local subcmd="$words[2]"

  case "$subcmd" in
    sessions)
      _arguments -s \
        '--grep[Filter by content (regex)]:pattern:' \
        '--path[Filter by path (regex)]:pattern:' \
        '--since[Time filter (duration: 5m,1h,2d or date string)]:spec:' \
        '--limit[Show last N sessions]:count:' \
        '--format[Output format]:format:(list jsonl)' \
        '--help[Show help]' \
        '*:session:_files'
      ;;
    timeline)
      _arguments -s \
        '-t[Filter by type (UTRFWBGASQDI)]:types:' \
        '--width[Truncation width]:width:' \
        '--timestamps[Show timestamps]' \
        '--no-timestamps[Disable timestamps]' \
        '--color=-[Color output]::mode:(auto always none)' \
        '--emoji[Always show emoji]' \
        '--no-emoji[Never show emoji]' \
        '--grep[Filter events by desc (regex)]:pattern:' \
        '-A[Show N turns after grep match]:count:' \
        '--after[Show N turns after grep match]:count:' \
        '-B[Show N turns before grep match]:count:' \
        '--before[Show N turns before grep match]:count:' \
        '-C[Show N turns before and after grep match]:count:' \
        '--context[Show N turns before and after grep match]:count:' \
        '--since[Show events since (duration or date)]:spec:' \
        '--last-since[Show events since duration before session end]:duration:' \
        '--last-turn[Show last N turns]:count:' \
        '--md=-[Full text for Q/T/R/U events]::mode:(auto source render none)' \
        '--jsonl=-[JSONL output]::mode:(none redact full)' \
        '--help[Show help]' \
        '*:session:_files'
      ;;
    file-ops)
      _arguments -s \
        '*-d[Detail level (repeatable: -d, -dd)]' \
        '--detail=-[Detail level (0/1/2)]::level:(0 1 2)' \
        '--help[Show help]' \
        ':session:_files'
      ;;
    resolve)
      _arguments -s \
        '--path[Force file path output]' \
        '--all[Show all matches per prefix]' \
        '--help[Show help]' \
        '*:session_id_prefix:'
      ;;
    completion)
      _arguments -s \
        '--help[Show help]' \
        ':shell:(zsh)'
      ;;
    *)
      _files
      ;;
  esac
}

_claude-session-analysis "$@"
